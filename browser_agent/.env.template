# Browser Automation Agent — environment variables
#
# Copy this file to .env and fill in the keys for the providers you use.
# The agent loads this file automatically via python-dotenv.

# ── Anthropic Claude (model: claude-sonnet-4-5) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Azure OpenAI GPT-4o (model: azure-gpt-4o) ────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o   # optional — override if deployment name differs

# ── Google Gemini (model: gemini-2.0-flash) ───────────────────────────────────
GOOGLE_API_KEY=AIza...
